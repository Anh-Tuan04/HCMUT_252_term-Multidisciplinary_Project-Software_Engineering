// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ================= ENUM =================
enum Role {
  USER
  MANAGER
  ADMIN
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  MAINTAIN
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  ERROR
}

model User {
  id        Int            @id @default(autoincrement())
  firstName String
  lastName  String
  email     String         @unique
  password  String
  username  String         @unique
  role      Role           @default(USER)
  code      String?
  expiresAt DateTime?
  tokens    RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model ParkingLot {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(100)
  location String? @db.VarChar(255)

  devices IoTDevice[]
  slots   ParkingSlot[]
}

model IoTDevice {
  macAddress String       @id @db.VarChar(50)
  lotId      Int?
  deviceName String?      @db.VarChar(50)
  status     DeviceStatus @default(ACTIVE)

  lot   ParkingLot?   @relation(fields: [lotId], references: [id])
  slots ParkingSlot[]

  @@index([lotId])
}

model ParkingSlot {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(10)

  lotId      Int
  deviceMac  String @db.VarChar(50)
  portNumber Int

  status SlotStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot    ParkingLot @relation(fields: [lotId], references: [id])
  device IoTDevice  @relation(fields: [deviceMac], references: [macAddress])

  @@unique([deviceMac, portNumber])
  @@unique([lotId, name])
  @@index([status])
  @@index([lotId])
  @@index([deviceMac])
}
